msgid "龙 - 法术"
msgstr ""

#: how_to_play | https://hsreplay.net/battlegrounds/comps/73/
msgid "[[Fire-Forged Evoker||120301]] scales with the amount of spells you cast. Your spell generation is mainly going to come from cycling cards with [[Brann Bronzebeard||96786]] and [[Visionary Shipman||126810]]. As long as you cycle free cards such as [[Tavern Tempest||64077]] and [[Shell Collector||80740]], you should get 20 or more procs on your [[Fire-forged Evoker||120301]] a turn. Leave [[Persistent Poet||108463]] on your board to capture permanent stats every fight. Finally, at some point you may sell your spell generation setup to end on premium dragons such as [[Stuntdrake||127238]] and [[Twilight Broodmother||127236]]"
msgstr ""

#: when_to_commit | https://hsreplay.net/battlegrounds/comps/73/
msgid "[[Fire-fuled Evoker||120301]] + [[Visionary Shipman||126810]] + 经济 ([[Brann Bronzebeard||96786]])"
msgstr ""

#: common_enablers | https://hsreplay.net/battlegrounds/comps/73/
